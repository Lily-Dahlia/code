import urllib.parse
import urllib.request
import sys

def shorten_url(url):
    """Función que conecta con la API de TinyURL para acortar una URL."""
    try:
        api_url = "http://tinyurl.com/api-create.php?" + urllib.parse.urlencode({"url": url})
        with urllib.request.urlopen(api_url) as response:
            return response.read().decode("utf-8")
    except Exception as e:
        return f"Error al acortar la URL: {e}"

def main():
    print("--- ACORTADOR DE ENLACES CASERO ---")
    
    # Permite pasar la URL por argumento de terminal o pedirla interactivamente
    if len(sys.argv) > 1:
        url_larga = sys.argv[1]
    else:
        url_larga = input("Introduce la URL larga que deseas acortar: ").strip()
    
    if not url_larga:
        print("No introdujiste ninguna URL válida.")
        return

    print("\nProcesando...")
    url_corta = shorten_url(url_larga)
    
    print("\n¡Listo! Tu URL acortada es:")
    print(f"🔗 {url_corta}\n")

if __name__ == "__main__":
    main()
